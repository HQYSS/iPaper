{
  "manifest_version": 3,
  "name": "iPaper 导入助手",
  "description": "从 arXiv 页面和 PDF 页面一键导入论文到本机 iPaper。",
  "version": "0.1.0",
  "key": "",
  "permissions": [
    "activeTab",
    "contextMenus",
    "nativeMessaging",
    "scripting",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1:3000/*",
    "http://localhost:5173/*",
    "https://arxiv.org/*"
  ],
  "action": {
    "default_title": "导入 iPaper",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://arxiv.org/abs/*",
        "https://arxiv.org/html/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
