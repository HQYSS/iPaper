#!/bin/bash

# iPaper 一键启动脚本
# 启动后端、前端和 Electron 应用

PROJECT_DIR="/Users/admin/workspace/iPaper"
LOG_DIR="$PROJECT_DIR/logs"
mkdir -p "$LOG_DIR"

# 绝对路径
PYTHON="/Users/admin/miniconda3/bin/python"
NPM="/opt/homebrew/bin/npm"
NODE="/opt/homebrew/bin/node"

# 设置 PATH 以便子进程也能找到命令
export PATH="/opt/homebrew/bin:/Users/admin/miniconda3/bin:$PATH"

# 清理旧进程
cleanup() {
    echo "正在清理旧进程..."
    pkill -f "uvicorn main:app" 2>/dev/null
    pkill -f "vite.*iPaper" 2>/dev/null
    sleep 1
}

# 启动后端
start_backend() {
    echo "启动后端服务..."
    cd "$PROJECT_DIR/backend"
    nohup "$PYTHON" -m uvicorn main:app --host 127.0.0.1 --port 8000 > "$LOG_DIR/backend.log" 2>&1 &
    echo "后端 PID: $!"
}

# 启动前端开发服务器
start_frontend() {
    echo "启动前端开发服务器..."
    cd "$PROJECT_DIR/frontend"
    nohup "$NPM" run dev > "$LOG_DIR/frontend.log" 2>&1 &
    echo "前端 PID: $!"
}

# 等待服务就绪
wait_for_services() {
    echo "等待服务启动..."
    
    # 等待后端
    for i in {1..30}; do
        if curl -s http://127.0.0.1:8000/health > /dev/null 2>&1; then
            echo "后端已就绪"
            break
        fi
        sleep 1
    done
    
    # 等待前端
    for i in {1..30}; do
        if curl -s http://localhost:5173 > /dev/null 2>&1; then
            echo "前端已就绪"
            break
        fi
        sleep 1
    done
}

# 启动 Electron
start_electron() {
    echo "启动 Electron 应用..."
    cd "$PROJECT_DIR/electron"
    ./node_modules/electron/dist/Electron.app/Contents/MacOS/Electron . --dev --skip-backend
}

# 主流程
cleanup
start_backend
start_frontend
wait_for_services
start_electron
